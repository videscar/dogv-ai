# Base
DOGV_BASE_URL=https://dogv.gva.es
DATABASE_URL=postgresql+psycopg2://dogv_ai:dogv_ai@localhost:5432/dogv_ai
DOGV_DB_DSN=postgresql://dogv_ai:dogv_ai@localhost:5432/dogv_ai

# llama.cpp (chat + embeddings, OpenAI-compatible HTTP)
# Chat server (e.g. qwen3.6-27b GGUF), can be shared with other projects on the host.
LLM_BASE_URL=http://127.0.0.1:8000
LLM_MODEL=qwen3.6-27b
LLM_TIMEOUT=300
LLM_MAX_TOKENS=8192
# Embedding server (bge-m3), spawned/managed by scripts/demo_ctl.sh on a separate port.
EMBED_BASE_URL=http://127.0.0.1:8001
EMBED_MODEL=bge-m3
EMBED_TIMEOUT=60

# Retrieval lanes (comma-separated): vector,bm25,title
ASK_LANES=vector,bm25,title

# Retrieval tuning
ASK_MAX_DOCS=20
ASK_MIN_DOCS=3
ASK_MAX_FACETS=3
ASK_READ_MAX_DOCS=3
ASK_CHUNKS_PER_DOC=4
ASK_READ_COVERAGE_DOCS=2
ASK_READ_ELIGIBILITY_DOCS=1
ASK_READ_AMOUNT_DOCS=1
ASK_CHUNK_MAX_CHARS=1200
ASK_DOC_FALLBACK_CHARS=12000
ASK_RERANK_TOP_N=5
ASK_RERANK_MAX_CANDIDATES=10
ASK_RERANK_EXPAND_CANDIDATES=10
ASK_RERANK_EXPAND_TOP_N=2
ASK_RERANK_COVERAGE_KEEP=4
ASK_DOC_CONFIDENCE_MIN=0.06
ASK_RRF_EXPAND_MARGIN_RATIO=0.12
ASK_RRF_MARGIN_PROBE=5
ASK_MAX_DOCS_EXPAND=20
ASK_READ_EXPAND_DOCS=2
ASK_BM25_MAX_DOCS=50
ASK_RRF_WEIGHT_VECTOR=1.0
ASK_RRF_WEIGHT_BM25=1.0
ASK_RRF_WEIGHT_TITLE=1.0
ASK_RRF_WEIGHT_TITLE_LEXICAL=0.8
ASK_FALLBACK_ALLOW_MARGIN=false
BM25_FUSE_WEIGHT_CHUNK=1.0
BM25_FUSE_WEIGHT_STRICT=1.2
BM25_FUSE_WEIGHT_TITLE=0.9
BM25_STRICT_PRIMARY_MIN=1
BM25_PRF_DOCS=5
BM25_PRF_TERMS=6
ASK_TEMPORAL_POLICY=filter
TEMPORAL_TIMEZONE=Europe/Madrid
TEMPORAL_WEEK_START=monday
ASK_LLM_EXPAND=true

# Embeddings / chunking
EMBEDDING_DIM=1024
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=80

# Full-doc reading limits
FULL_DOC_MAX_DOCS=2
FULL_DOC_MAX_CHARS=120000
FULL_DOC_TOTAL_CHARS=200000

# Ingest/backfill
AUTO_INGEST_ENABLED=false
AUTO_INGEST_MAX_DAYS=15
AUTO_INGEST_KEEP_MONTHS=12
AUTO_INGEST_LANGUAGES=es_es,va_va
DOGV_CLASSIFY_WORKERS=2
# Optional: split classify calls across multiple llama-server endpoints (one per GPU)
# DOGV_CLASSIFY_LLM_URLS=http://127.0.0.1:8000,http://127.0.0.1:8002
AUTO_INGEST_STARTUP_ENABLED=true
AUTO_INGEST_STARTUP_BLOCKING=false
AUTO_INGEST_STARTUP_PURGE_OLD=true
AUTO_INGEST_STARTUP_REPAIR_GAPS=true
AUTO_INGEST_STARTUP_LOCK_ID=190021
AUTO_INGEST_GAP_CHECK_RETRIES=3
AUTO_INGEST_GAP_CHECK_BACKOFF_SECONDS=1.5
AUTO_INGEST_GAP_REPAIR_SCAN_MAX_DAYS=45
BACKFILL_ENABLED=false
HOT_INDEX_MONTHS=6
WARM_INDEX_MONTHS=24

# Demo behavior
DEMO_ENFORCE_READY_GATE=true
# Set DEMO_REQUEST_TIMEOUT_SECONDS=0 (or "none") to disable UI request timeout.
DEMO_REQUEST_TIMEOUT_SECONDS=60
ANSWER_MUTATORS_ENABLED=false
ANSWER_MISSING_NOTES_ENABLED=false
ANSWER_VALIDATOR_ENABLED=true
ANSWER_REPAIR_ATTEMPTS=1
ANSWER_CLAIM_GUARD_MODE=current_strict
ANSWER_REPAIR_MODE=conditional
ANSWER_FALLBACK_STYLE=concise_summary
ANSWER_FALLBACK_MAX_ITEMS=3
CHAINLIT_BACKEND_URL=http://127.0.0.1:8088
CHAINLIT_ENABLE_DATA_LAYER=false

# Tracing
TRACE_ENABLED=false
